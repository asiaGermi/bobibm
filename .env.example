# Financial Risk Management API - Environment Variables Template
# Copy this file to .env and update with your values

# ============================================================================
# Application Settings
# ============================================================================

# Application name
FRM_APP_NAME=Financial Risk Management API

# Application version
FRM_APP_VERSION=1.0.0

# API prefix for all endpoints
FRM_API_PREFIX=/api/v1

# ============================================================================
# Data Settings
# ============================================================================

# Path to the transaction dataset CSV file
# Default: /app/data/raw/HI-Small_Trans.csv (inside container)
# For local development: ./data/raw/HI-Small_Trans.csv
FRM_DATA_PATH=/app/data/raw/HI-Small_Trans.csv

# ============================================================================
# CORS Settings
# ============================================================================

# Allowed origins for CORS (comma-separated or *)
# Examples:
#   - Single origin: http://localhost:3000
#   - Multiple origins: http://localhost:3000,https://app.example.com
#   - All origins: *
FRM_CORS_ORIGINS=*

# Allow credentials in CORS requests
FRM_CORS_ALLOW_CREDENTIALS=true

# Allowed HTTP methods (comma-separated or *)
FRM_CORS_ALLOW_METHODS=*

# Allowed HTTP headers (comma-separated or *)
FRM_CORS_ALLOW_HEADERS=*

# ============================================================================
# Logging Settings
# ============================================================================

# Log level: debug, info, warning, error, critical
LOG_LEVEL=info

# Python logging settings
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# ============================================================================
# Server Settings
# ============================================================================

# Host to bind the server (0.0.0.0 for all interfaces)
SERVER_HOST=0.0.0.0

# Port to bind the server
SERVER_PORT=8000

# Enable auto-reload on code changes (development only)
SERVER_RELOAD=false

# Number of worker processes (production)
SERVER_WORKERS=1

# ============================================================================
# Security Settings (Future)
# ============================================================================

# JWT secret key (uncomment when JWT is implemented)
# JWT_SECRET_KEY=your-secret-key-here

# JWT algorithm
# JWT_ALGORITHM=HS256

# JWT token expiration in minutes
# JWT_EXPIRATION_MINUTES=60

# ============================================================================
# Performance Settings
# ============================================================================

# Enable request caching
ENABLE_CACHING=true

# Cache TTL in seconds
CACHE_TTL=300

# Maximum concurrent requests
MAX_CONCURRENT_REQUESTS=100

# Request timeout in seconds
REQUEST_TIMEOUT=60

# ============================================================================
# Monitoring Settings (Future)
# ============================================================================

# Enable metrics collection
# ENABLE_METRICS=true

# Metrics endpoint
# METRICS_ENDPOINT=/metrics

# Enable health check endpoint
ENABLE_HEALTH_CHECK=true

# Health check endpoint
HEALTH_CHECK_ENDPOINT=/api/v1/health

# ============================================================================
# Database Settings (Future - if Redis is added)
# ============================================================================

# Redis host
# REDIS_HOST=localhost

# Redis port
# REDIS_PORT=6379

# Redis password
# REDIS_PASSWORD=

# Redis database number
# REDIS_DB=0

# ============================================================================
# watsonx Orchestrate Settings (Future)
# ============================================================================

# watsonx Orchestrate API endpoint
# WXO_API_ENDPOINT=https://api.watsonx.ibm.com

# watsonx Orchestrate API key
# WXO_API_KEY=your-api-key-here

# watsonx Orchestrate instance ID
# WXO_INSTANCE_ID=your-instance-id

# ============================================================================
# Development Settings
# ============================================================================

# Enable debug mode (development only)
DEBUG=false

# Enable API documentation
ENABLE_DOCS=true

# Enable ReDoc documentation
ENABLE_REDOC=true

# ============================================================================
# Docker Settings
# ============================================================================

# Container user ID (matches non-root user in Dockerfile)
CONTAINER_UID=1000

# Container group ID
CONTAINER_GID=1000

# ============================================================================
# Notes
# ============================================================================
# 
# 1. Copy this file to .env: cp .env.example .env
# 2. Update values as needed for your environment
# 3. Never commit .env file to version control
# 4. For production, use secure secret management
# 5. Environment variables prefixed with FRM_ are read by pydantic-settings
#